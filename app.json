{
  "expo": {
    "name": "Ryft",
    "slug": "ryft",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "ryft",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#0E0E0E",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ryft.app"
    },
    "android": {
      "package": "com.ryft.app",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0E0E"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "color": "#FFFFFF"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ryft needs access to your photos to attach progress pics to your journal.",
          "cameraPermission": "Ryft needs your camera to capture today's grind."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0E0E0E",
          "dark": {
            "backgroundColor": "#0E0E0E"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aa0db7eb-04fd-4f35-94ce-a9e7404202c3"
      }
    },
    "owner": "waylm"
  }
}
